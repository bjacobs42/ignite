SHOPIFY_STORE_URL=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=

GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

GOOGLE_SHEET_ID=

MAX_DAILY_ACTIVATE=10

# First-run setup: manually write 0 into Config Sheet!E2 before first deploy.
# If E2 is empty, previousActive defaults to 0. On a large store this means
# currentActive - 0 will likely exceed MAX_DAILY_ACTIVATE, causing an early exit.
